{
  "expo": {
    "name": "cc",
    "slug": "claudecode-mobile",
    "scheme": "claudecode",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Connect to your Claude daemon over your private Tailscale network."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan the pairing QR shown on your daemon machine",
          "barcodeScannerEnabled": true,
          "recordAudioAndroid": false
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
